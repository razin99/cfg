# vim:filetype=zsh
{{- $overlay := include (joinPath "overlays" .chezmoi.hostname "dot_zshrc.yaml") | fromYaml }}
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="af-magic"

# Plugins loaded
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
plugins=(
  chezmoi
  docker
  docker-compose
  git
  mise
  npm
  pip
  tmux
  z
  {{ join "\n  " $overlay.plugins }}
)

{{- if stat "/opt/homebrew/bin/brew" }}
export FPATH="$(/opt/homebrew/bin/brew --prefix)/share/zsh/site-functions:${FPATH}"
export PATH="$PATH:/opt/homebrew/bin"
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end }}

source $ZSH/oh-my-zsh.sh

{{- if stat "/opt/homebrew/bin/op" }}
eval "$(op completion zsh)"; compdef _op op
{{ end -}}

export PATH=$PATH:{{- $overlay.paths | join ":" }}

alias cp="cp -i"
{{- range $k, $v := $overlay.aliases }}
alias {{ $k }}="{{ $v }}"
{{- end -}}
