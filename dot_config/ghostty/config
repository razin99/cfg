command = /bin/zsh
click-repeat-interval = 500

auto-update = download
auto-update-channel = stable

font-family = Hack Nerd Font Mono
font-size = 18

theme = One Half Dark

keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right
 
keybind = ctrl+a>shift+\=new_split:right
keybind = ctrl+a>shift+-=new_split:down

keybind = ctrl+a>ctrl+h=resize_split:left,32
keybind = ctrl+a>ctrl+j=resize_split:down,32
keybind = ctrl+a>ctrl+k=resize_split:up,32
keybind = ctrl+a>ctrl+l=resize_split:right,32

keybind = ctrl+a>space=equalize_splits

keybind = ctrl+a>t=new_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab

keybind = ctrl+a>w=close_surface

keybind = global:cmd+/=toggle_quick_terminal
